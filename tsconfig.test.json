{
  "include": ["tests"],
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "target": "es6",
    "module": "commonjs",
    "outDir": "dist-tests",
    "downlevelIteration": true,
    "lib": ["dom", "esnext"],
    "declaration": false,
    "sourceMap": false,
    "esModuleInterop": true
  }
}
